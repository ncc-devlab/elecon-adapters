{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elecon.grades.list",
  "title": "成绩列表",
  "type": "object",
  "required": ["term", "items"],
  "properties": {
    "term": {
      "type": "string",
      "description": "学期标识，如 2025-2026-2"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["courseId", "courseName", "credit", "score", "category", "status"],
        "properties": {
          "courseId": { "type": "string" },
          "courseName": { "type": "string" },
          "credit": { "type": "number", "minimum": 0 },
          "score": {
            "type": "object",
            "required": ["kind", "value"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["numeric", "letter", "passfail"]
              },
              "value": {},
              "max": { "type": "number" }
            }
          },
          "gradePoint": { "type": "number" },
          "category": {
            "type": "string",
            "enum": ["required", "elective", "unknown"]
          },
          "status": {
            "type": "string",
            "enum": ["final", "provisional", "unknown"]
          }
        }
      }
    }
  }
}
