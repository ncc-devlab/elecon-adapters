{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elecon.grades.list",
  "title": "成绩列表",
  "type": "object",
  "required": ["term", "items"],
  "properties": {
    "term": {
      "type": "string",
      "description": "学期标识，如 2025-2026-2"
    },
    "academicYear": { "type": "string" },
    "termName": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "page": { "type": "integer", "minimum": 1 },
    "size": { "type": "integer", "minimum": 1 },
    "cursor": { "type": "string" },
    "total": { "type": "integer", "minimum": 0 },
    "hasNext": { "type": "boolean" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["courseId", "courseName", "credit", "score", "category", "status"],
        "properties": {
          "courseId": { "type": "string" },
          "courseName": { "type": "string" },
          "credit": { "type": "number", "minimum": 0 },
          "creditType": { "type": "string" },
          "courseNature": { "type": "string" },
          "courseCategory": { "type": "string" },
          "courseGroup": { "type": "string" },
          "language": { "type": "string" },
          "teacher": { "type": "string" },
          "offeringUnit": { "type": "string" },
          "classNo": { "type": "string" },
          "sectionNo": { "type": "string" },
          "examMethod": { "type": "string" },
          "examAt": { "type": "string", "format": "date-time" },
          "retake": { "type": "boolean" },
          "sourceStatus": { "type": "string", "enum": ["normal", "retake", "makeup", "deferred", "exempt", "改分", "withdrawn", "unknown"] },
          "rank": { "type": "integer", "minimum": 1 },
          "gradeDistribution": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
          "courseAverage": { "type": "number" },
          "score": {
            "type": "object",
            "required": ["kind", "value"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["numeric", "letter", "passfail", "unknown"]
              },
              "value": {},
              "raw": { "type": "string" },
              "status": { "type": "string", "enum": ["known", "unknown", "absent", "notReleased", "exempt"] },
              "max": { "type": "number" }
            }
          },
          "gradePoint": { "type": "number" },
          "category": {
            "type": "string",
            "enum": ["required", "elective", "unknown"]
          },
          "status": {
            "type": "string",
            "enum": ["final", "provisional", "unknown"]
          }
        }
      }
    }
  }
}
