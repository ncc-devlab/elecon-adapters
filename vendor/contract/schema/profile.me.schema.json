{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elecon.profile.me",
  "title": "个人资料",
  "type": "object",
  "properties": {
    "name": { "type": "string" }, "studentIdMasked": { "type": "string" },
    "department": { "type": "string" }, "major": { "type": "string" },
    "grade": { "type": "string" }, "identityType": { "type": "string", "enum": ["undergraduate", "graduate", "faculty", "staff", "other", "unknown"] },
    "campus": { "type": "string" }, "updatedAt": { "type": "string", "format": "date-time" }
  }
}
