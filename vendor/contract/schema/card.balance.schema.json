{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elecon.card.balance",
  "title": "一卡通余额",
  "type": "object",
  "required": ["cardNumber", "balance"],
  "properties": {
    "cardNumber": { "type": "string" },
    "cardNumberMasked": { "type": "string" },
    "cardType": { "type": "string" },
    "accountType": { "type": "string" },
    "campus": { "type": "string" },
    "wallet": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "frozen", "lost", "cancelled", "unknown"] },
    "balanceUpdatedAt": { "type": "string", "format": "date-time" },
    "snapshotAt": { "type": "string", "format": "date-time" },
    "errorStatus": { "type": "string", "enum": ["failed", "pending", "unknown"] },
    "balance": {
      "type": "object",
      "required": ["amountMinor", "currency"],
      "properties": {
        "amountMinor": { "type": "integer", "description": "最小货币单位，如分" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "lastTransaction": {
      "type": "object",
      "properties": {
        "amountMinor": { "type": "integer" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "time": { "type": "string", "format": "date-time" },
        "merchant": { "type": "string" }
      }
    }
  }
}
