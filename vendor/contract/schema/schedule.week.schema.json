{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elecon.schedule.week",
  "title": "周课表",
  "type": "object",
  "required": ["term", "week", "days"],
  "properties": {
    "term": { "type": "string" },
    "academicYear": { "type": "string" },
    "termStartDate": { "type": "string", "format": "date" },
    "termEndDate": { "type": "string", "format": "date" },
    "teachingWeekStart": { "type": "string", "format": "date" },
    "teachingWeekEnd": { "type": "string", "format": "date" },
    "weekType": { "type": "string", "enum": ["teaching", "exam", "holiday", "unknown"] },
    "updatedAt": { "type": "string", "format": "date-time" },
    "sourceSystem": { "type": "string" },
    "week": { "type": "integer", "minimum": 1 },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dayOfWeek", "slots"],
        "properties": {
          "dayOfWeek": { "type": "integer", "minimum": 1, "maximum": 7 },
          "slots": {
            "type": "array",
            "items": {
              "type": "object",
                "required": ["start", "end", "courseName"],
              "properties": {
                "start": { "type": "string" },
                "end": { "type": "string" },
                "courseName": { "type": "string" },
                  "courseId": { "type": "string" },
                  "date": { "type": "string", "format": "date" },
                  "timeStart": { "type": "string" },
                  "timeEnd": { "type": "string" },
                  "campus": { "type": "string" },
                  "building": { "type": "string" },
                  "room": { "type": "string" },
                  "roomCapacity": { "type": "integer", "minimum": 0 },
                  "courseNature": { "type": "string" },
                  "classNo": { "type": "string" },
                  "language": { "type": "string" },
                  "courseUrl": { "type": "string", "format": "uri" },
                  "group": { "type": "string" },
                  "onlineUrl": { "type": "string", "format": "uri" },
                  "meetingNumberPresent": { "type": "boolean" },
                  "meetingPasswordPresent": { "type": "boolean" },
                  "changeType": { "type": "string", "enum": ["none", "rescheduled", "cancelled", "makeup", "substitute", "temporaryRoom", "unknown"] },
                  "changeReason": { "type": "string" },
                  "weekExceptions": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
                "teacher": { "type": "string" },
                "location": { "type": "string" },
                "weeks": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    }
  }
}
